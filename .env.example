# claude-launch configuration
# Copyright (c) 2026 claude-launch contributors
# 仅供学习与研究使用；其他用途后果自负。
#
# Copy this file to one of:
#   ./.env                             # project-local
#   ~/.config/claude-launch/.env       # user-global (created by install.sh)
#   ~/.claude-launch.env
#
# For CLAUDE_LAUNCH_* and CLAUDE_BIN, higher-priority .env files override stale shell exports.
#
# Required:

# OpenAI-compatible API base (no trailing /chat/completions)
CLAUDE_LAUNCH_BASE_URL=https://your-gateway.example/v1

# Model name sent to POST {BASE}/chat/completions
CLAUDE_LAUNCH_MODEL=gpt-5

# Optional request-model mapping. By default every Claude model maps to
# CLAUDE_LAUNCH_MODEL via {"*":"<CLAUDE_LAUNCH_MODEL>"}.
# CLAUDE_LAUNCH_MODEL_MAP_JSON={"*":"gpt-5","opus":"gpt-5","sonnet":"gpt-5","claude-opus-*":"gpt-5","claude-sonnet-*":"gpt-5"}

# API Key Configuration: Specify either a single key via CLAUDE_LAUNCH_API_KEY or multiple comma-separated keys via CLAUDE_LAUNCH_API_KEYS for rotation.
CLAUDE_LAUNCH_API_KEY=sk-your-key-here
# CLAUDE_LAUNCH_API_KEYS=key1,key2,key3

# Optional:

# Model passed to `claude --model` when you do not specify one on the command line.
# Full model ids and Claude aliases both work. Default: claude-sonnet-5
# CLAUDE_LAUNCH_CLI_MODEL=claude-sonnet-5

# Default Claude effort passed to `claude --effort` when you do not specify one.
# Supported: low, medium, high, xhigh, max
# CLAUDE_LAUNCH_CLI_EFFORT=high

# Claude settings sources loaded by the child Claude Code process.
# Default is "user" to prevent project .claude/settings.json from overriding
# ANTHROPIC_BASE_URL / ANTHROPIC_API_KEY with unrelated Anthropic auth settings.
# Use "default" or "inherit" to leave Claude Code behavior unchanged.
# CLAUDE_LAUNCH_SETTING_SOURCES=user

# Optional display name exposed on GET /v1/models
# CLAUDE_LAUNCH_MODEL_DISPLAY_NAME=gpt-5.4

# Upstream HTTP User-Agent. Defaults to a curl-like value because some gateways
# reject Python urllib's default signature.
# CLAUDE_LAUNCH_USER_AGENT=curl/8.5.0

# Add Codex-style upstream request headers when enabled.
# CODEX_HEAD=true
# CODEX_VERSION=0.144.6
# CODEX_BIN=codex
# CODEX_ORIGINATOR=codex_cli_rs
# CODEX_USER_AGENT=
# CODEX_SESSION_ID=
# CODEX_THREAD_ID=
# CODEX_INSTALLATION_ID=
# CODEX_OPENAI_BETA=

# Optional fallback reasoning effort sent upstream when the Claude request does
# not carry output_config.effort.
# Supported: none, minimal, low, medium, high, xhigh
# CLAUDE_LAUNCH_REASONING_EFFORT=medium

# Default maximum completion tokens / thinking limit
# CLAUDE_LAUNCH_MAX_COMPLETION_TOKENS=

# Default maximum context length/tokens limit
# CLAUDE_LAUNCH_MAX_TOKENS=

# Dummy API key expected by the local proxy. Usually no reason to change it.
# CLAUDE_LAUNCH_LOCAL_API_KEY=claude-launch-local

# Path to claude binary
# CLAUDE_BIN=claude

# Force a specific .env file (highest priority)
# CLAUDE_LAUNCH_ENV=/path/to/custom.env

# Log proxy requests
# CLAUDE_LAUNCH_VERBOSE=1

# Write debug JSON dumps here (default: $TMPDIR/claude-launch)
# CLAUDE_LAUNCH_DEBUG_DIR=/tmp/claude-launch

# Append redacted request/response capture logs for troubleshooting.
# CLAUDE_LAUNCH_CAPTURE_LOG=1
# CLAUDE_LAUNCH_CAPTURE_LOG_FILE=/tmp/claude-launch/capture.jsonl

# Bind proxy to a fixed port (default: ephemeral)
# CLAUDE_LAUNCH_PORT=0
